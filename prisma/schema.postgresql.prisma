  roleAr       String          @default("")
  bioEn        String          @default("") @db.Text
  bioAr        String          @default("") @db.Text
  email        String          @default("")
  phone        String          @default("")
  locationEn   String          @default("")
  locationAr   String          @default("")
  skills       Json            @default("[]")
  imageUrl     String          @default("")
  sortOrder    Int             @default(0)
  isPublished  Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([directoryId, departmentId, sortOrder])
}

model PartnerProgram {
  id            String            @id @default(cuid())
  slug          String            @unique @db.VarChar(64)
  titleEn       String
  titleAr       String
  descriptionEn String            @default("") @db.Text
  descriptionAr String            @default("") @db.Text
