// // --- Conversion & forms platform ---

// --- Conversion & forms platform ---

model FormTemplate {
  id          String               @id @default(cuid())
  name        String
  slug        String               @unique @db.VarChar(64)
  category    FormTemplateCategory @default(GENERAL)
  description String?              @db.Text
  definition  Json                 @default("{}")
  isPublished Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  submissions FormSubmission[]
  drafts      FormDraft[]

  @@index([category, isPublished])
}

model FormSubmission {
  id           String               @id @default(cuid())
  templateId   String?
  template     FormTemplate?        @relation(fields: [templateId], references: [id], onDelete: SetNull)
  blockType    String?              @db.VarChar(64)
  blockId      String?              @db.VarChar(64)
  pageId       String?              @db.VarChar(36)
  pageSlug     String?              @db.VarChar(256)
  locale       String               @default("en") @db.VarChar(16)
  payload      Json                 @default("{}")
  score        Int                  @default(0)
  status       FormSubmissionStatus @default(NEW)
  utm          Json                 @default("{}")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  webhooks     FormWebhookDelivery[]

  @@index([templateId, createdAt])
  @@index([status, createdAt])
  @@index([blockType])
}

model FormDraft {
  id          String       @id @default(cuid())
  token       String       @unique @db.VarChar(64)
  templateId  String
  template    FormTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  payload     Json         @default("{}")
  currentStep Int          @default(0)
  expiresAt   DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([templateId])
  @@index([expiresAt])
}

model NewsletterSubscriber {
  id           String                     @id @default(cuid())
  email        String                     @db.VarChar(120)
  name         String?
  segment      String                     @default("default") @db.VarChar(64)
  status       NewsletterSubscriberStatus @default(PENDING)
  confirmToken String?                    @unique @db.VarChar(64)
  confirmedAt  DateTime?
  locale       String                     @default("en") @db.VarChar(16)
  metadata     Json                       @default("{}")
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  @@unique([email, segment])
  @@index([status, segment])
  @@index([createdAt])
}

model DownloadGateUnlock {
  id            String               @id @default(cuid())
  token         String               @unique @db.VarChar(64)
  mediaAssetId  String
  mediaAsset    MediaAsset           @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  email         String?
  unlockMethod  DownloadUnlockMethod @default(FORM)
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime             @default(now())

  @@index([mediaAssetId])
  @@index([expiresAt])
}

model FormWebhookDelivery {
  id           String                    @id @default(cuid())
  submissionId String
  submission   FormSubmission            @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  url          String                    @db.VarChar(512)
  status       FormWebhookDeliveryStatus @default(PENDING)
  responseCode Int?
  error        String?                   @db.Text
  createdAt    DateTime                  @default(now())

  @@index([submissionId])
}
