        "answerFormat": "plain",
        "items": [
          {
            "question": "What areas does BRT's fiber network cover?",
            "answer": "Our fiber network spans 47 PoPs across the region with ongoing expansion. Fixed wireless coverage extends our reach to over 95% of the territory. Contact our sales team for a specific site survey."
          },
          {
            "question": "Do you offer SLA-backed connectivity for enterprises?",
            "answer": "Yes. All business-grade circuits come with a 99.97% uptime SLA, guaranteed MTR (mean time to restore) of under 4 hours, and 24/7 dedicated support backed by financial credits."
          },
          {
            "question": "Can BRT support multi-site SD-WAN deployments?",
            "answer": "Absolutely. Our SD-WAN fabric supports hybrid underlay (fiber + wireless + 5G), centralized policy management, per-application QoS and real-time visibility across all sites from a single portal."
          },
          {
            "question": "What is the white-label MVNO program?",
            "answer": "The BRT MVNO program gives ISPs and brands access to our licensed spectrum, infrastructure, BSS/OSS and support teams. You market under your own brand while we handle the network operations."
          }
        ]
      }
