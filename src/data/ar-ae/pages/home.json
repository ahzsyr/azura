          },
          {
            "icon": "⚡",
            "title": "Edge Compute Nodes",
            "description": "Distributed MEC nodes co-located at PoPs for ultra-low latency compute at the network edge."
          },
          {
            "icon": "🔁",
            "title": "SD-WAN Fabric",
            "description": "Policy-driven multi-path routing across fiber, wireless and 5G with intelligent failover."
          },
          {
            "icon": "🖥️",
            "title": "NOC Dashboard",
            "description": "Real-time network visibility with per-customer telemetry, SLA alerting and automated runbooks."
          },
          {
            "icon": "🔌",
            "title": "Power & UPS",
            "description": "Managed DC power plants, online UPS and automatic generator transfer for 100% power continuity."
          },
