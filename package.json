{
  "name": "azura",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:apply-default-photo": "tsx scripts/apply-default-photo.ts",
    "db:studio": "prisma studio",
    "seo:validate": "node scripts/seo/validate-seo.mjs",
    "test:i18n": "tsx --test src/i18n/__tests__/url-helpers.test.ts src/features/translation/__tests__/i18n-core.test.ts",
    "test:blocks": "tsx --test src/features/builder/__tests__/*.test.ts",
    "test:comparison": "tsx --test src/features/comparison/__tests__/*.test.ts",
    "i18n:validate": "node scripts/i18n/validate-i18n.mjs",
    "i18n:backfill": "tsx scripts/i18n/backfill-translations.ts",
    "i18n:verify-parity": "tsx scripts/i18n/verify-parity.ts",
    "content:verify": "tsx scripts/content/verify-migration.ts",
    "catalog:copy": "tsx scripts/catalog/copy-astro-data.ts",
    "catalog:copy:force": "tsx scripts/catalog/copy-astro-data.ts --force",
    "catalog:verify": "tsx scripts/catalog/verify-catalog.ts",
    "catalog:index": "tsx scripts/catalog/build-product-index.ts",
    "catalog:index:force": "tsx scripts/catalog/build-product-index.ts --force",
    "prebuild": "npm run catalog:index",
    "catalog:seed-header": "tsx scripts/catalog/seed-header-json.ts",
    "catalog:migrate-header-logos": "tsx scripts/catalog/migrate-header-logos.ts",
    "content:migrate-fks": "tsx scripts/content/migrate-inquiry-booking-fks.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@hookform/resolvers": "^5.0.1",
    "@nanostores/react": "^1.1.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@uploadthing/react": "^7.3.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.16.0",
    "fuse.js": "^7.4.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.513.0",
    "nanostores": "^1.3.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.28",
    "next-intl": "^4.1.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.57.0",
    "tailwind-merge": "^3.3.0",
    "uploadthing": "^7.7.3",
    "zod": "^3.25.51",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "@radix-ui/react-slot": "1.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5"
  }
}
