{
  "name": "azura",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "sync:placeholder": "node scripts/sync-placeholder.mjs",
    "middleware:manifest": "node scripts/build/generate-middleware-manifest.mjs",
    "profile:generate": "node scripts/build/generate-deployment-profile.mjs",
    "profiles:verify": "tsx scripts/profiles/verify-deployment-profile.ts",
    "platform:verify": "tsx scripts/platform/verify-cleanup.ts",
    "custom-entity-types:verify": "node scripts/ci/verify-custom-entity-types.mjs",
    "test:middleware-gates": "tsx --test src/middleware/__tests__/middleware-gates.test.ts",
    "dev": "node scripts/sync-placeholder.mjs && node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev",
    "build": "node scripts/deploy/production-build.mjs",
    "build:vercel": "node scripts/deploy/vercel-next-build.mjs",
    "build:hostinger": "node --max-old-space-size=4096 scripts/deploy/hostinger-build.mjs",
    "build:hostinger:standalone": "node scripts/deploy/hostinger-standalone-build.mjs",
    "diagnose:hostinger": "node scripts/deploy/diagnose-hostinger-fs.mjs",
    "test:db": "node scripts/deploy/test-db-connection.mjs",
    "test:db:hostinger": "node scripts/deploy/run-with-env-hostinger.mjs test:db",
    "db:generate:hostinger": "node scripts/deploy/run-with-env-hostinger.mjs db:generate",
    "build:standalone": "next build && node scripts/deploy/assemble-standalone.mjs",
    "prebuild": "node scripts/sync-placeholder.mjs && node scripts/deploy/prebuild.mjs",
    "prestart": "node scripts/deploy/log-runtime-db-env.mjs && node scripts/deploy/prestart-prisma.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:templates": "eslint src/templates",
    "typecheck": "npm exec -- tsc --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run knip && npm run direction:verify && npm run ci:cloud-native-fs && npm run ci:cloud-native-reads && npm run build:vercel",
    "knip": "knip",
    "depcheck": "depcheck",
    "db:deploy": "prisma migrate deploy",
    "db:migrate:deploy": "node scripts/deploy/prisma-migrate-deploy.mjs",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "deploy:hostinger-db": "node scripts/deploy/hostinger-db-setup.mjs",
    "deploy:warmup": "node scripts/deploy/warm-isr.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:zero-data": "tsx scripts/reset/zero-data.ts",
    "db:reset-setup": "tsx scripts/reset/reset-setup.ts",
    "db:factory-defaults": "tsx scripts/reset/factory-defaults.ts",
    "cms:ensure-pages": "tsx scripts/ensure-cms-pages.ts",
