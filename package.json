    "test:blocks": "tsx --test src/schemas/__tests__/*.test.ts src/lib/zod/__tests__/*.test.ts src/features/announcement-bar/__tests__/*.test.ts src/features/builder/__tests__/*.test.ts src/features/builder/migration/__tests__/*.test.ts src/features/builder/blocks/commerce/commerce-showcase/__tests__/*.test.ts src/features/builder/blocks/content/__tests__/*.test.ts src/features/builder/blocks/marketing/__tests__/*.test.ts src/features/builder/blocks/commerce/product-blocks/__tests__/*.test.ts src/features/builder/blocks/conversion/__tests__/*.test.ts src/features/builder/blocks/discovery/__tests__/*.test.ts src/features/builder/blocks/media/__tests__/*.test.ts src/features/builder/blocks/portal/__tests__/*.test.ts src/presets/pricing/__tests__/*.test.ts src/features/forms/__tests__/*.test.ts",
    "test:comparison": "tsx --test src/features/comparison/__tests__/*.test.ts",
    "test:resolvers": "tsx --test src/resolvers/__tests__/*.test.ts src/resolvers/product/__tests__/*.test.ts src/resolvers/content-preset/__tests__/*.test.ts src/resolvers/knowledge/__tests__/*.test.ts src/resolvers/team-member/__tests__/*.test.ts src/resolvers/partner/__tests__/*.test.ts src/resolvers/pricing/__tests__/*.test.ts src/presets/release/__tests__/*.test.ts src/features/content/schemas/__tests__/content-list-block.test.ts",
    "test:entities": "tsx --test src/features/entities/__tests__/*.test.ts",
    "test:performance": "tsx --test src/lib/performance/__tests__/*.test.ts",
    "perf:bundle": "node scripts/performance/bundle-report.mjs",
    "perf:routes": "node scripts/performance/slow-routes-report.mjs",
    "perf:cwv": "node scripts/performance/capture-cwv-baseline.mjs",
    "perf:catalog-shadow": "tsx scripts/performance/catalog-isr-shadow-parity.ts",
    "perf:hydration": "node scripts/performance/hydration-audit.mjs",
    "perf:regression": "node scripts/performance/performance-regression-budget.mjs",
    "perf:validate": "node scripts/performance/validate-budgets.mjs",
    "i18n:validate": "node scripts/i18n/validate-i18n.mjs",
    "i18n:backfill": "tsx scripts/i18n/backfill-translations.ts",
    "i18n:backfill:workspace": "tsx scripts/i18n/backfill-workspace-translations.ts",
    "i18n:inventory": "tsx scripts/i18n/generate-migration-inventory.ts",
    "i18n:verify-parity": "tsx scripts/i18n/verify-parity.ts",
    "i18n:verify-architecture": "tsx scripts/i18n/verify-architecture.ts",
    "i18n:export-ui-messages": "tsx scripts/i18n/export-ui-messages-to-files.ts",
    "content:verify": "tsx scripts/content/verify-migration.ts",
    "entities:inventory": "tsx scripts/entities/inventory-catalog-storage.ts",
    "entities:migrate-products": "tsx scripts/entities/migrate-products-to-content-items.ts",
    "entities:verify-migration": "tsx scripts/entities/verify-entity-migration.ts",
    "entities:rollback-products": "tsx scripts/entities/rollback-products-migration.ts",
    "entities:reindex-products": "tsx scripts/entities/reindex-migrated-products.ts",
    "catalog:copy": "tsx scripts/catalog/archive/copy-astro-data.ts",
    "catalog:copy:force": "tsx scripts/catalog/archive/copy-astro-data.ts --force",
    "catalog:verify": "tsx scripts/catalog/verify-catalog.ts",
    "search:verify": "tsx scripts/search/verify-search-index.ts",
    "capabilities:verify": "tsx scripts/capabilities/verify-ownership.ts",
    "catalog:index": "tsx scripts/catalog/build-product-index.ts",
    "catalog:index:force": "tsx scripts/catalog/build-product-index.ts --force",
    "catalog:seed-db": "tsx scripts/catalog/seed-products-db.ts",
    "catalog:seed-collections": "tsx scripts/catalog/seed-collections-db.ts",
    "catalog:seed-site-settings": "tsx scripts/catalog/seed-site-settings-db.ts",
    "catalog:seed-all": "tsx scripts/catalog/seed-all-db.ts",
    "ci:cloud-native-fs": "node scripts/ci/check-cloud-native-fs.mjs",
    "ci:cloud-native-reads": "node scripts/ci/check-cloud-native-reads.mjs",
    "direction:verify": "node scripts/ci/check-direction-guardrails.mjs",
    "ci:smoke-cloud-native": "node scripts/ci/smoke-cloud-native.mjs",
    "collections:build-hierarchy": "tsx scripts/collections/build-brt-hierarchy-json.ts",
    "catalog:seed-header": "tsx scripts/catalog/seed-header-json.ts",
    "catalog:seed-theme-presets": "tsx scripts/catalog/seed-theme-presets.ts",
    "catalog:migrate-header-logos": "tsx scripts/catalog/migrate-header-logos.ts",
    "content:migrate-fks": "tsx scripts/content/migrate-inquiry-booking-fks.ts",
    "postinstall": "node scripts/prisma-generate.mjs && node scripts/deploy/ensure-prisma-client.mjs",
    "db:generate": "node scripts/prisma-generate.mjs"
