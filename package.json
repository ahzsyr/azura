{
  "name": "azura",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "sync:placeholder": "node scripts/sync-placeholder.mjs",
    "dev": "node scripts/sync-placeholder.mjs && node --max-old-space-size=8192 ./node_modules/next/dist/bin/next dev",
    "build": "node scripts/deploy/production-build.mjs",
    "build:vercel": "node scripts/prisma-generate.mjs && next build",
    "build:hostinger": "node --max-old-space-size=4096 scripts/deploy/hostinger-build.mjs",
    "build:hostinger:standalone": "node scripts/deploy/hostinger-standalone-build.mjs",
    "diagnose:hostinger": "node scripts/deploy/diagnose-hostinger-fs.mjs",
    "test:db": "node scripts/deploy/test-db-connection.mjs",
    "test:db:hostinger": "node scripts/deploy/run-with-env-hostinger.mjs test:db",
    "db:generate:hostinger": "node scripts/deploy/run-with-env-hostinger.mjs db:generate",
    "build:standalone": "next build && node scripts/deploy/assemble-standalone.mjs",
    "prebuild": "node scripts/sync-placeholder.mjs && node scripts/deploy/prebuild.mjs",
    "prestart": "node scripts/deploy/log-runtime-db-env.mjs && node scripts/deploy/prestart-prisma.mjs",
    "start": "next start",
    "lint": "eslint",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "deploy:hostinger-db": "node scripts/deploy/hostinger-db-setup.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:zero-data": "tsx scripts/reset/zero-data.ts",
    "db:reset-setup": "tsx scripts/reset/reset-setup.ts",
    "db:factory-defaults": "tsx scripts/reset/factory-defaults.ts",
    "cms:ensure-pages": "tsx scripts/ensure-cms-pages.ts",
    "db:seed-brt": "tsx scripts/seed/regenerate-brt-website.ts",
    "db:seed-demo-brt": "tsx scripts/seed/regenerate-brt-website.ts",
    "db:seed-demo-safar": "tsx scripts/seed/regenerate-safar-website.ts",
    "db:export": "tsx scripts/database/export-imports.ts",
    "db:reset-admin": "tsx scripts/database/fix-admin.ts",
    "db:apply-default-photo": "tsx scripts/apply-default-photo.ts",
    "db:studio": "prisma studio",
    "db:apply-customer-profile": "node scripts/apply-customer-profile-columns.mjs",
    "seo:validate": "node scripts/seo/validate-seo.mjs",
    "test:i18n": "tsx --test src/i18n/__tests__/url-helpers.test.ts src/features/translation/__tests__/i18n-core.test.ts",
    "test:blocks": "tsx --test src/features/announcement-bar/__tests__/*.test.ts src/features/builder/__tests__/*.test.ts src/features/content-blocks/__tests__/*.test.ts src/features/marketing-blocks/__tests__/*.test.ts src/features/product-blocks/__tests__/*.test.ts src/features/conversion-blocks/__tests__/*.test.ts src/features/discovery-blocks/__tests__/*.test.ts src/features/media-blocks/__tests__/*.test.ts src/features/portal-blocks/__tests__/*.test.ts src/features/pricing-plans/__tests__/*.test.ts src/features/forms/__tests__/*.test.ts",
    "test:comparison": "tsx --test src/features/comparison/__tests__/*.test.ts",
    "test:performance": "tsx --test src/lib/performance/__tests__/*.test.ts",
    "perf:bundle": "node scripts/performance/bundle-report.mjs",
    "perf:routes": "node scripts/performance/slow-routes-report.mjs",
    "perf:validate": "node scripts/performance/validate-budgets.mjs",
    "i18n:validate": "node scripts/i18n/validate-i18n.mjs",
    "i18n:backfill": "tsx scripts/i18n/backfill-translations.ts",
    "i18n:verify-parity": "tsx scripts/i18n/verify-parity.ts",
    "content:verify": "tsx scripts/content/verify-migration.ts",
    "catalog:copy": "tsx scripts/catalog/copy-astro-data.ts",
    "catalog:copy:force": "tsx scripts/catalog/copy-astro-data.ts --force",
    "catalog:verify": "tsx scripts/catalog/verify-catalog.ts",
    "catalog:index": "tsx scripts/catalog/build-product-index.ts",
    "catalog:index:force": "tsx scripts/catalog/build-product-index.ts --force",
    "collections:build-hierarchy": "tsx scripts/collections/build-brt-hierarchy-json.ts",
    "catalog:seed-header": "tsx scripts/catalog/seed-header-json.ts",
    "catalog:migrate-header-logos": "tsx scripts/catalog/migrate-header-logos.ts",
    "content:migrate-fks": "tsx scripts/content/migrate-inquiry-booking-fks.ts",
    "postinstall": "node scripts/prisma-generate.mjs && node scripts/deploy/ensure-prisma-client.mjs",
    "db:generate": "node scripts/prisma-generate.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@hookform/resolvers": "^5.0.1",
    "@nanostores/react": "^1.1.0",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@tiptap/extension-highlight": "^3.25.0",
    "@tiptap/extension-image": "^3.25.0",
    "@tiptap/extension-link": "^3.25.0",
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/extension-text-align": "^3.25.0",
    "@tiptap/pm": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "@uploadthing/react": "^7.3.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.16.0",
    "fuse.js": "^7.4.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.513.0",
    "nanostores": "^1.3.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.28",
    "next-intl": "^4.1.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.57.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "shiki": "^4.2.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "uploadthing": "^7.7.3",
    "zod": "^3.25.51",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "@radix-ui/react-slot": "1.2.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6"
  }
}
