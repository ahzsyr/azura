# =========================
# Core runtime
# =========================
NODE_ENV=production
PORT=3000
SETUP_COMPLETE=false
INTERNAL_APP_URL=http://127.0.0.1:3000

# =========================
# Prisma + database (PostgreSQL / Supabase)
# =========================
PRISMA_SCHEMA=postgresql
DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# Deploy migrations only — Supabase → Database → Connection string → Direct (port 5432). Avoids pool ECHECKOUTTIMEOUT during `npm run build`.
# DIRECT_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# =========================
# Auth
# =========================
AUTH_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=CHANGE_TO_LONG_RANDOM_SECRET
NEXTAUTH_URL=https://your-domain.com

# =========================
# Public site metadata
# =========================
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=AZURA
NEXT_PUBLIC_SITE_SHORT_NAME=AZ
NEXT_PUBLIC_SITE_TAGLINE=Solutions
NEXT_PUBLIC_WHATSAPP_MESSAGE=Hello, I would like to get in touch with {brandName}.
NEXT_PUBLIC_WHATSAPP_NUMBER=966500000000
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=
NEXT_PUBLIC_GA_ID=

# =========================
# Files manager connection (Supabase storage)
# =========================
MEDIA_STORAGE=supabase
SUPABASE_MEDIA_BUCKET=media
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# =========================
# App data mode (recommended for hosted runtime)
# =========================
CATALOG_DATA_SOURCE=db
CATALOG_PRODUCTS_SOURCE=db
CATALOG_USE_JSON_STORE=1

# =========================
# Setup seed defaults
# =========================
SEED_ADMIN_EMAIL=admin@your-domain.com
SEED_ADMIN_PASSWORD=Admin123
SEED_COMPANY_EMAIL=info@your-domain.com

# =========================
# Email providers (pick one or configure both)
# =========================
EMAIL_FROM=info@your-domain.com
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# =========================
# Webhooks / jobs / integrations
# =========================
WEBHOOK_SIGNING_SECRET=CHANGE_TO_RANDOM_SECRET
CRON_SECRET=CHANGE_TO_RANDOM_SECRET
SEARCH_INDEX_RUN_SECRET=CHANGE_TO_RANDOM_SECRET
SEO_INTEGRATION_RUN_SECRET=CHANGE_TO_RANDOM_SECRET
SEO_ANALYTICS_RUN_SECRET=CHANGE_TO_RANDOM_SECRET
SEO_INTEGRATION_SECRET=CHANGE_TO_RANDOM_SECRET

# =========================
# Optional AI / SEO providers
# =========================
OPENAI_API_KEY=
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=

# =========================
# Optional UploadThing
# =========================
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
