{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/*.{ts,tsx}",
    "src/middleware.ts",
    "scripts/**/*.{ts,mjs,js}",
    "prisma/seed.ts",
    "prisma/seed-content.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs,js}",
    "prisma/**/*.{ts,prisma}"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "src/generated/**",
    ".next/**",
    "scripts/i18n/archive/**",
    "scripts/catalog/archive/**"
  ],
  "ignoreDependencies": [
    "eslint-config-next",
    "@types/bcryptjs",
    "@types/nodemailer",
    "@types/papaparse",
    "playwright",
    "yaml",
    "depcheck",
    "knip"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off",
    "duplicates": "off"
  },
  "next": {
    "entry": [
      "src/app/**/*.{ts,tsx}",
      "src/middleware.ts"
    ]
  }
}
