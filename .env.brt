# Hostinger hPanel — brt-me.com (custom domain)
# Copy EVERY line into: Websites → Node.js → Environment variables
# Do not rely on uploading this file alone; hPanel env vars are what the live app reads.

NODE_ENV=production

# After setup wizard completes, set true so middleware treats setup as complete when status API is unavailable.
SETUP_COMPLETE=true

# Coming soon is controlled in Admin → Settings → Site. Optional COMING_SOON_ENABLED env is a fallback only when /api/setup/status is unreachable.

# Middleware self-fetch fallback — use loopback so Hostinger Node can reach /api/setup/status locally.
INTERNAL_APP_URL=http://127.0.0.1:3000

# Supabase PostgreSQL — copy host/user/password from Supabase → Database → Connection string → URI
# Project ref: xxvvokguzrcrshplzqwp | Region pooler: aws-1-ap-southeast-2 (do NOT use aws-0-us-east-1)
# DB password reset 2026 — no special chars, no URL encoding needed.
# Use transaction pooler (6543 + pgbouncer) on Hostinger — session pooler (5432) exhausts connections at runtime.
PRISMA_SCHEMA=postgresql
DATABASE_URL=postgresql://postgres.xxvvokguzrcrshplzqwp:Brttradingllc2026@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=3&sslmode=require

NEXT_PUBLIC_SUPABASE_URL=https://xxvvokguzrcrshplzqwp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_jn-LGqvdPamfE66IHaDtqA_zSqinkgr

# CMS media uploads — add service_role BEFORE setting MEDIA_STORAGE=supabase
# Supabase → Project Settings → API → service_role (secret; never expose in browser)
# Until the key is set, uploads use public/uploads on the Hostinger server.
# SUPABASE_SERVICE_ROLE_KEY=paste-service-role-secret-here
# MEDIA_STORAGE=supabase
SUPABASE_MEDIA_BUCKET=media

# Session pooler (5432) — avoid on Hostinger; limited pool size causes "connection pool exhausted":
# DATABASE_URL=postgresql://postgres.xxvvokguzrcrshplzqwp:Brttradingllc2026@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# Direct (IPv6-only — often unreachable from Hostinger; use pooler above):
# DATABASE_URL=postgresql://postgres:Brttradingllc2026@db.xxvvokguzrcrshplzqwp.supabase.co:5432/postgres?sslmode=require

# Optional — only for root db.js (not used by Next.js / Prisma)
SUPABASE_URL=https://xxvvokguzrcrshplzqwp.supabase.co
