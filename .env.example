# Deployment profile — default enterprise preserves full surface.
# Set at build time: marketing | showroom | agency | tourism | documentation | enterprise
AZURA_PROFILE=enterprise

# Set to 1 to emit [publish-propagation] logs correlating shell save → layout render.
# PUBLISH_PROPAGATION_LOG=1
#
# Manual verify (save vs publish on public marketing site):
# 1. Change announcement bar → Save → marketing site unchanged on reload
# 2. Click Publish → marketing site shows new bar on first load
# 3. Change header overlay → Save → site unchanged; Publish → overlay live
# 4. Theme: Save draft → preview cookie works; Publish → live site updates
#
# Database auto-migrate on deploy (Vercel production build + optional GitHub Action):
# SKIP_DB_MIGRATE=1          — disable automatic schema patches during build
# RUN_DB_MIGRATE_ON_PREVIEW=1 — run migrate on Vercel preview deployments too
#
# Supabase (Vercel + Hostinger sharing one DB):
# DATABASE_URL — transaction pooler, port 6543:
#   postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# DIRECT_URL — optional; omit if it duplicates session pooler or has stale credentials.
# Session pooler (preferred for migrate on Vercel + Hostinger):
#   postgresql://postgres.[ref]:[password]@aws-[region].pooler.supabase.com:5432/postgres?sslmode=require
# db.[ref].supabase.co direct works from some hosts only; migrate script tries session pooler first.
# If SEO integrations monitoring tables are missing, run database/postgres/12- SEO tables migration in Supabase SQL editor.
#
# Public site URL — fallback when the request host is unavailable (emails, background jobs).
# Sitemap URLs and OAuth use whichever domain you are browsing; set this for production email links.
# For Google OAuth, register each distinct domain you admin from (any TLD — unrelated domains are fine):
#   https://ali.com/api/seo/analytics/google/oauth/callback
#   https://other-brand.com/api/seo/analytics/google/oauth/callback
NEXT_PUBLIC_SITE_URL=https://your-domain.com
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=144847907068-32i184clvajkjdav8ueshnrjgn9ir7e3.apps.googleusercontent.com
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=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
#
# SEO integration secrets (OAuth tokens, API keys) are encrypted at rest in JsonStore.
# Uses SEO_INTEGRATION_SECRET if set, otherwise AUTH_SECRET / NEXTAUTH_SECRET.
# Keep this value stable across deploys — changing it invalidates stored integration tokens.
# AUTH_SECRET=your-stable-auth-secret
# SEO_INTEGRATION_SECRET=optional-dedicated-secret-for-seo-integrations
