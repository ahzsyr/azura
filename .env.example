DATABASE_URL="mysql://user:password@localhost:3306/azura"
# Auth.js v5 (preferred) — NEXTAUTH_* still supported as fallbacks
AUTH_SECRET="change-me-to-a-secure-random-string"
AUTH_TRUST_HOST="true"
NEXTAUTH_SECRET="change-me-to-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""
NEXT_PUBLIC_WHATSAPP_NUMBER="966500000000"
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL="https://www.google.com/maps/embed?pb="
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_GA_ID=""

# AZURA template — client branding (overrides until Company/Theme are saved in admin)
NEXT_PUBLIC_SITE_NAME="AZURA"
NEXT_PUBLIC_SITE_SHORT_NAME="AZ"
NEXT_PUBLIC_SITE_TAGLINE="Solutions"
NEXT_PUBLIC_WHATSAPP_MESSAGE="Assalamu Alaikum, I would like to get in touch with {brandName}."

# Seed defaults (fresh database)
SEED_ADMIN_EMAIL="admin@localhost"
SEED_ADMIN_PASSWORD="admin123"
SEED_COMPANY_EMAIL="info@localhost"
