# Vercel — azura-sooty.vercel.app
# Copy EVERY line into: Vercel → Project → Settings → Environment variables
# Project ref: jixnbfsupldsyojqxfcv

NODE_ENV=production

# After setup wizard completes, set true so middleware serves the public site when status API self-fetch fails.
SETUP_COMPLETE=true

# Middleware self-fetch fallback — use the public Vercel URL (or VERCEL_URL in preview deployments).
INTERNAL_APP_URL=https://azura-sooty.vercel.app

# Supabase PostgreSQL — project ref: jixnbfsupldsyojqxfcv
# Copy host/user/password from Supabase → Database → Connection string → URI
# Region pooler: aws-1-ap-northeast-1 (copy host from Supabase → Connect → Transaction pooler)
# Use transaction pooler (6543 + pgbouncer) on Vercel — session pooler (5432) exhausts connections at runtime.
PRISMA_SCHEMA=postgresql
DATABASE_URL=postgresql://postgres.jixnbfsupldsyojqxfcv:Ahz151993azura@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5&sslmode=require

# Session pooler (5432) — avoid on Vercel; limited pool size causes "connection pool exhausted":
# DATABASE_URL=postgresql://postgres.jixnbfsupldsyojqxfcv:Ahz151993azura@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# Direct (IPv6-only — often unreachable from Vercel; use pooler above):
# DATABASE_URL=postgresql://postgres:Ahz151993azura@db.jixnbfsupldsyojqxfcv.supabase.co:5432/postgres?sslmode=require

NEXT_PUBLIC_SUPABASE_URL=https://jixnbfsupldsyojqxfcv.supabase.co
